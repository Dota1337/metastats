{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "metastats.gg Companion",
    "version": "0.1.0",
    "minimum-overwolf-version": "0.275.0",
    "author": "metastats.gg",
    "icon": "images/IconMouseOver.png",
    "icon_gray": "images/IconMouseNormal.png",
    "launcher_icon": "images/launcher_icon.ico",
    "splash_image": "images/splash.png",
    "description": "Aggregiert anonyme Position- und Comp-Daten aus deinen TFT-Spielen, um metastats.gg's Pro-Statistiken zu verbessern. Kein Display, keine Beratung — nur stille Hintergrund-Telemetrie."
  },
  "permissions": [
    "GameInfo",
    "Extensions"
  ],
  "data": {
    "start_window": "background",
    "windows": {
      "background": {
        "file": "windows/background.html",
        "is_background_page": true,
        "show_in_taskbar": false,
        "transparent": true,
        "clickthrough": true,
        "resizable": false,
        "size": { "width": 1, "height": 1 }
      },
      "desktop": {
        "file": "windows/desktop.html",
        "show_in_taskbar": true,
        "transparent": false,
        "resizable": true,
        "size": { "width": 560, "height": 720 },
        "min_size": { "width": 480, "height": 520 }
      },
      "lobby": {
        "file": "windows/lobby.html",
        "in_game_only": true,
        "transparent": true,
        "resizable": true,
        "show_in_taskbar": false,
        "size": { "width": 320, "height": 480 },
        "min_size": { "width": 280, "height": 360 },
        "topmost": true,
        "is_alt_f4_blocked": false,
        "start_position": { "top": 80, "left": 80 }
      }
    },
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [5426, 21570]
    },
    "game_events": [5426, 21570],
    "launch_events": [
      {
        "event": "GameLaunch",
        "tracked": true,
        "event_data": {
          "game_ids": [5426, 21570]
        },
        "start_minimized": true
      }
    ],
    "externally_connectable": {
      "matches": [
        "https://metastats.gg/*",
        "https://*.metastats.gg/*"
      ]
    },
    "extra-objects": {},
    "user_agent": "metastats-companion/0.1"
  }
}
